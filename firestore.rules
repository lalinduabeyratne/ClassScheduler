rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && userDoc(request.auth.uid).data.role == "admin";
    }
    function isStudent() {
      return isSignedIn() && userDoc(request.auth.uid).data.role == "student";
    }
    function myStudentId() {
      return userDoc(request.auth.uid).data.studentId;
    }
    function studentCanUpdateOwnPaymentSlip() {
      return isStudent()
        && resource.data.studentId == myStudentId()
        && request.resource.data.studentId == resource.data.studentId
        && resource.data.status in ["pending_verification", "rejected"]
        && request.resource.data.status == "pending_verification"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "slipPath",
          "slipUrl",
          "status",
          "updatedAt",
        ]);
    }
    function slotHasValidTimeRange(slot) {
      return slot.startTime is string
        && slot.endTime is string
        && slot.duration is int
        && slot.duration > 0;
    }
    function slotHasStudents(slot) {
      return slot.students is list;
    }
    function createSlotAllowed() {
      return isAdmin()
        && request.resource.data.isLocked == true
        && request.resource.data.active is bool
        && request.resource.data.recurring == true
        && request.resource.data.exceptions is list
        && slotHasValidTimeRange(request.resource.data)
        && slotHasStudents(request.resource.data);
    }
    function unlockOnlyUpdateAllowed() {
      return resource.data.isLocked == true
        && request.resource.data.isLocked == false
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["isLocked"]);
    }
    function unlockedEditAllowed() {
      return resource.data.isLocked == false
        && slotHasValidTimeRange(request.resource.data)
        && slotHasStudents(request.resource.data);
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin(); // admin sets role + studentId mappings
    }

    match /students/{studentId} {
      allow read: if isAdmin() || (isStudent() && myStudentId() == studentId);
      allow write: if isAdmin();
    }

    match /timetableSlots/{slotId} {
      allow read: if isSignedIn();
      allow create: if createSlotAllowed();
      allow update: if isAdmin() && (unlockOnlyUpdateAllowed() || unlockedEditAllowed());
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isStudent() && resource.data.studentId == myStudentId());
      allow create, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isStudent() && resource.data.studentId == myStudentId());
      allow create: if isAdmin() || (
        isStudent()
        && request.resource.data.studentId == myStudentId()
        && request.resource.data.status == "pending_verification"
      );
      allow update: if isAdmin() || studentCanUpdateOwnPaymentSlip();
      allow delete: if isAdmin();
    }

    match /rescheduleRequests/{id} {
      allow read: if isAdmin() || (isStudent() && resource.data.studentId == myStudentId());
      allow create: if isStudent() && request.resource.data.studentId == myStudentId();
      allow update: if isAdmin(); // approval/rejection
      allow delete: if false;
    }
  }
}

